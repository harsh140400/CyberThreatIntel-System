# NEXUS CTI Platform — Backend Environment Variables
# Copy this to .env and fill in your values

# ── Application ──────────────────────────────────────────────────
APP_NAME=NEXUS CTI Platform
DEBUG=false

# ── Security ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# JWT token expiry in minutes (default 8h)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./nexus_cti.db

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list for production; keep localhost for dev
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── AI / Anthropic ───────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Feed Settings ────────────────────────────────────────────────
FEED_REFRESH_INTERVAL_SECONDS=60
MAX_FEED_ITEMS=500
